  // COVER SCREEN
  document.documentElement.classList.add('cover-lock');
  const coverEl = document.getElementById('coverScreen');
  function dismissCover(){
    coverEl.classList.add('cover-hidden');
    document.documentElement.classList.remove('cover-lock');
  }
  coverEl.addEventListener('click', dismissCover);
  document.getElementById('coverEnterBtn').addEventListener('click', (e)=>{ e.stopPropagation(); dismissCover(); });
  document.getElementById('brandReturnBtn').addEventListener('click', ()=>{
    coverEl.classList.remove('cover-hidden');
    document.documentElement.classList.add('cover-lock');
  });

  function switchView(name){
    document.querySelectorAll('.view').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(el => {
      el.classList.toggle('active', el.dataset.view === name);
      if(el.dataset.view === name){ el.setAttribute('aria-current','page'); }
      else{ el.removeAttribute('aria-current'); }
    });
    const target = document.getElementById('view-' + name);
    if(target){ target.classList.add('active'); }
    window.scrollTo({ top: document.querySelector('section.hero').offsetHeight, behavior:'smooth' });
  }

  function switchSubview(name){
    document.querySelectorAll('.subview').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.subtab-btn').forEach(el => el.classList.toggle('active', el.dataset.sub === name));
    document.getElementById('sub-' + name).classList.add('active');
  }

  // PROJECT DETAIL MODAL (single-image carousel + click-to-zoom)
  const projModal = document.getElementById('projModal');
  const pmStage = document.getElementById('pmStage');
  const pmImage = document.getElementById('pmImage');
  const pmTag = document.getElementById('pmTag');
  const pmTitle = document.getElementById('pmTitle');
  const pmDesc = document.getElementById('pmDesc');
  const pmNext = document.getElementById('pmNext');
  let currentProject = null;
  let currentIndex = 0;

  function showImage(){
    const p = PROJECT_DATA[currentProject];
    pmImage.src = p.images[currentIndex];
    pmImage.alt = p.title;
    pmStage.scrollTop = 0;
    pmStage.scrollLeft = 0;
  }
  function openProject(id){
    const p = PROJECT_DATA[id];
    if(!p) return;
    currentProject = id;
    currentIndex = 0;
    showImage();
    pmTag.textContent = p.tag;
    pmTitle.textContent = p.title;
    pmDesc.textContent = p.desc;
    projModal.classList.add('proj-modal-open');
    document.documentElement.classList.add('modal-lock');
  }
  function closeProject(){
    projModal.classList.remove('proj-modal-open');
    document.documentElement.classList.remove('modal-lock');
  }
  function nextImage(){
    const p = PROJECT_DATA[currentProject];
    if(!p) return;
    currentIndex = (currentIndex + 1) % p.images.length;
    showImage();
  }
  document.querySelectorAll('.project-row-item').forEach(row => {
    row.addEventListener('click', () => openProject(row.dataset.project));
  });
  document.getElementById('pmClose').addEventListener('click', closeProject);
  pmNext.addEventListener('click', nextImage);
  projModal.addEventListener('click', (e) => { if(e.target === projModal) closeProject(); });

  // FULLSCREEN IMAGE LIGHTBOX (pinch/scroll to zoom natively)
  const imgLightbox = document.getElementById('imgLightbox');
  const lightboxImage = document.getElementById('lightboxImage');
  function openLightbox(){
    lightboxImage.src = pmImage.src;
    lightboxImage.alt = pmImage.alt;
    imgLightbox.classList.add('lightbox-open');
  }
  function closeLightbox(){
    imgLightbox.classList.remove('lightbox-open');
  }
  pmImage.addEventListener('click', openLightbox);
  document.getElementById('lightboxClose').addEventListener('click', closeLightbox);

  document.querySelectorAll('[data-view]').forEach(btn => {
    btn.addEventListener('click', () => switchView(btn.dataset.view));
  });
  document.querySelectorAll('[data-sub]').forEach(btn => {
    btn.addEventListener('click', () => switchSubview(btn.dataset.sub));
  });
</script>

